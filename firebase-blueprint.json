{
  "entities": {
    "Notification": {
      "title": "Notification",
      "description": "Represents a broadcasted announcement or notice.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "branch": { "type": "string", "enum": ["All", "CSE", "Civil", "Mechanical", "EE", "ECE"] },
        "role": { "type": "string", "enum": ["All", "Faculty", "Student"] },
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "is_scheduled": { "type": "boolean" },
        "scheduled_for": { "type": "string", "format": "date-time" },
        "attachment_url": { "type": "string", "format": "uri" },
        "attachment_type": { "type": "string", "enum": ["pdf", "photo", "link"] }
      },
      "required": ["title", "message", "branch", "role", "created_at"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "staff", "student"] },
        "branch": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Student achievements and awards.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "branch": { "type": "string" },
        "student_name": { "type": "string" },
        "batch": { "type": "string" },
        "date": { "type": "string" },
        "image_url": { "type": "string" }
      },
      "required": ["title", "description", "student_name", "batch", "date"]
    },
    "StaffProfile": {
      "title": "Staff Profile",
      "description": "Profiles for faculty and staff members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "branch": { "type": "string" },
        "image_url": { "type": "string" },
        "bio": { "type": "string" }
      },
      "required": ["name", "designation", "branch"]
    },
    "ContentSection": {
      "title": "Content Section",
      "description": "Dynamic content for site pages.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "section_name": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image_url": { "type": "string" }
      },
      "required": ["section_name", "title", "content"]
    }
  },
  "firestore": {
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Global and branch-specific notifications."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions."
    },
    "/achievements/{achievementId}": {
      "schema": "Achievement",
      "description": "Wall of fame entries."
    },
    "/profiles/{profileId}": {
      "schema": "StaffProfile",
      "description": "Faculty and leadership profiles."
    },
    "/content/{contentId}": {
      "schema": "ContentSection",
      "description": "Static content sections like About, History, etc."
    }
  }
}
